# ---------------------------------------------------------------------------
# Server runtime
# ---------------------------------------------------------------------------
# One of: development | test | production
NODE_ENV=development
PORT=4000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string. Matches the docker-compose defaults.
DATABASE_URL="postgresql://saas:saas_dev_password@localhost:5432/saas_boilerplate?schema=public"

# Log verbosity: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins, or * to allow all.
# Example: CORS_ORIGIN=http://localhost:5173,https://app.example.com
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# Window length in milliseconds (default 900000 = 15 minutes).
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window, per client.
RATE_LIMIT_MAX=100
