# ---------------------------------------------------------------------------
# Server runtime
# ---------------------------------------------------------------------------
# One of: development | test | production
NODE_ENV=development
PORT=4000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string. Matches the docker-compose defaults.
DATABASE_URL="postgresql://saas:saas_dev_password@localhost:5432/saas_boilerplate?schema=public"

# ---------------------------------------------------------------------------
# Auth / tokens
# ---------------------------------------------------------------------------
# Secret for signing access-token JWTs. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ACCESS_TOKEN_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
# Optional (defaults shown): access 15m, refresh 30d.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# ---------------------------------------------------------------------------
# App & email
# ---------------------------------------------------------------------------
# Public client URL — used to build links in transactional emails.
APP_URL="http://localhost:5173"

EMAIL_FROM="SaaS Boilerplate Pro <no-reply@localhost>"
# Transport: "console" (logs emails — dev default) or "smtp" (actually sends).
EMAIL_TRANSPORT=console
# Required only when EMAIL_TRANSPORT=smtp:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-pass

# Log verbosity: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins, or * to allow all.
# Example: CORS_ORIGIN=http://localhost:5173,https://app.example.com
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# Window length in milliseconds (default 900000 = 15 minutes).
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window, per client.
RATE_LIMIT_MAX=100
