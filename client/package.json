{
  "name": "@saas-boilerplate/client",
  "version": "0.0.0",
  "private": true,
  "description": "SaaS Boilerplate Pro — frontend (React + Vite + TypeScript)",
  "type": "module",
  "engines": {
    "node": ">=20"
